library(readr)
library(dplyr)
runtime = read_csv('G:/博士课程/超算讲座资料/2024-09-21_change_2.csv', locale=locale(encoding="GBK"))
runtime$time_hour = sapply(strsplit(runtime$机时, '\\(h\\)'), function(x){
if(length(x)>1){
y = as.numeric(x[[1]])
} else {y = 0}
})
runtime$time_mins = sapply(strsplit(runtime$机时, '\\(h\\)'), function(x){
if(length(x)>1){
y = x[[2]]
} else {y = x[[1]]}
m = regexec("^[0-9]+", y)
y2 = as.numeric(regmatches(y, m)[[1]][1])
y3 = y2/60
return(y3)
})
runtime$month = sapply(strsplit(runtime$时间, ' '), function(x){
if(length(x)>1){
y = x[[1]]
} else {y = 0}
month = as.numeric(strsplit(y, '\\/')[[1]][2])
return(month)
})
runtime$alltime = runtime$time_hour+runtime$time_mins
runtime$true_price = abs(runtime$金额)/(runtime$cpu数*runtime$alltime)
runtime$cost = NA
runtime[runtime$month < 8,]$cost = runtime[runtime$month < 8,]$alltime*runtime[runtime$month < 8,]$cpu数*0.05
runtime[runtime$month >= 8,]$cost = runtime[runtime$month >= 8,]$alltime*runtime[runtime$month >= 8,]$cpu数*0.06
runtime$deviation = abs(runtime$金额)-runtime$cost
runtime = arrange(runtime, runtime$deviation)
View(runtime)
runtime = arrange(runtime, runtime$deviation, decreasing = T)
View(runtime)
runtime = arrange(runtime, desc(runtime$deviation))
View(runtime)
write_excel_csv(runtime, 'G:/博士课程/超算讲座资料/明细.csv')
