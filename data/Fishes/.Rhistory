## Load packages
library(sf)
library(rnaturalearth)
library(rnaturalearthdata)
library(rgeos)
library(ggspatial)
library(ggrepel)
library(tidyverse)
setwd("D:/Globe taxa distribution/Mammal_yaoqi_202407/code")
## Mapping sp distribution
# Import the primary result
setwd("D:/Globe taxa distribution/Mammal_yaoqi_202407")
sp_dis_1 = read.csv('PHYLNCINE DataS1/transform data/result_parallel.csv',
header = T)
sp_dis_2 = sp_dis_1[,-c(1,3)]
df = st_read("TDWG4/TDWG4_newTibet.shp")
# Cbind the richness data
sum(sp_dis_2[465,])
sp_dis_3 = cbind(sp_dis_2, richness = rowSums(sp_dis_2[,2:ncol(sp_dis_2)] > 0,
na.rm = T))
sp_dis_4 = sp_dis_3 %>% relocate(richness, .after = Region.ID)
df_joined = df %>% left_join(sp_dis_4[,c(1:2)],
join_by('RegionID' == 'Region.ID'))
# plot
sp_dis_map = ggplot(data =  df_joined) +
geom_sf(aes(fill = richness))+
xlab("Longitude") + ylab("Latitude") +
scale_fill_viridis_c(option = "plasma")+
ggtitle("Native mammal distribution",
subtitle = paste0("(", 'TDWG 4', ")"))+
coord_sf(crs = '+proj=cea +lat_ts=30 +lon_0=0 +x_0=0 +y_0=0 +datum=WGS84 +units=m +no_defs')+
guides(fill = guide_legend(byrow = TRUE))+
theme(plot.title = element_text(hjust = 0.5,
vjust=0.5, size=80, face='bold'),
panel.background = element_rect(fill = 'white', color = 'black'),
legend.key = element_rect(fill = "white"),
legend.text = element_text(size = 50),
legend.spacing.y = unit(2, 'cm'),
panel.border = element_blank(),panel.grid.major = element_blank(),
panel.grid.minor = element_blank(),axis.line = element_line(colour = "black"),
text = element_text(size = 80),
axis.ticks.y = element_line(linetype=1,color="black",linewidth=0.5),
axis.ticks.x = element_line(linetype=1,color="black",linewidth=0.5),
axis.ticks.length.y = unit(0.3,'cm'),
axis.ticks.length.x = unit(0.3,'cm'),
#legend.title = element_blank(),
axis.text.x = element_text(angle = 60, hjust = 1),
axis.text.y = element_text(angle = 0, vjust = 0.5),
axis.title.x = element_text(margin=margin(t=20)),
axis.title.y = element_text(margin=margin(t=20)))
sp_dis_map
df_joined
sum(df_joined$richness)
