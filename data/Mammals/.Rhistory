scale_fill_manual(name = "",breaks = c("Full.nonna","Conti.nonna"),
values = c("Full.nonna"=cbPalette[1], "Conti.nonna"=cbPalette[2])) +
stat_regline_equation(aes(x = LAT,y = ses_mntd_alien_1,
label = paste("Global","nat.",..adj.rr.label.., sep = "*\"  \"*")),
label.x = 8,label.y = -1.45,size=2.3)+
stat_regline_equation(aes(x = abs_LAT,y = ses_mntd_alien_2,
label = paste("Continent","nat.",..adj.rr.label.., sep = "*\"  \"*")),
label.x = 8,label.y = -1.6,size=2.3)+
theme_classic() +
labs(x = "Absolute latitude (°)",y = expression(Delta*"mntd (Mya)"))+
theme(axis.title =element_text(size=9),
axis.text = element_text(size = 7,colour = 'black'),
legend.title=element_blank(),
