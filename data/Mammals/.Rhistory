#### Plotting MNTD and its SES values ####
sf_com_mntd = TDWG4 %>% left_join(df_sp_mpd_ses_conti_pool,
join_by('RegionID' == 'RegionID'),
keep = F) %>%
left_join(df_sp_mpd_ses_global_pool[,c('RegionID', 'ses_mntd_alien_1', 'ses_mntd_alien_1')],
join_by('RegionID' == 'RegionID'),
keep = F)
sf_com_mntd = TDWG4 %>% left_join(df_sp_mpd_ses_conti_pool,
join_by('RegionID' == 'RegionID'),
keep = F) %>%
left_join(df_sp_mpd_ses_global_pool[,c('RegionID', 'ses_mpd_alien_1', 'ses_mntd_alien_1')],
join_by('RegionID' == 'RegionID'),
keep = F)
sf_com_mntd$LON = sf_com_mntd$LON/100000
sf_com_mntd$LAT = sf_com_mntd$LAT/100000
sf_com_mntd$abs_LAT = abs(sf_com_mntd$LAT)
sf_com_mntd$abs_LON = abs(sf_com_mntd$LON)
breaks_mntd = quantile(sf_com_mntd$obs_mntd_alien,
probs = seq(0, 1,
length.out = 9),
na.rm = TRUE)
breaks_mntd[1] = min(breaks_mntd[1], min(sf_com_mntd$obs_mntd_alien, na.rm = TRUE)) * 0.99
breaks_mntd[length(breaks_mntd)] = max(sf_com_mntd$obs_mntd_alien, na.rm = TRUE) * 1.01
sf_com_mntd$f_obs_mntd_alien = cut(sf_com_mntd$obs_mntd_alien,
breaks = breaks_mntd,
include.lowest = TRUE,
include.highest = T,
right = T,
dig.lab = 2)
breaks_sesmntd = quantile(sf_com_mntd$ses_mntd_alien_1,
probs = seq(0, 1,
length.out = 9),
na.rm = TRUE)
breaks_sesmntd[1] = min(breaks_sesmntd[1], min(sf_com_mntd$ses_mntd_alien_1, na.rm = TRUE)) * 0.99
breaks_sesmntd[length(breaks_sesmntd)] = max(sf_com_mntd$ses_mntd_alien_1, na.rm = TRUE) * 1.01
sf_com_mntd$f_ses_mntd_alien_1 = cut(sf_com_mntd$ses_mntd_alien_1,
breaks = breaks_sesmntd,
include.lowest = TRUE,
include.highest = T,
right = T,
dig.lab = 2)
obs_mntd_alien_map =
ggplot() +
geom_sf(data = countries, color = 'gray', fill = NA) +
geom_sf(data = bb, color = "gray", fill = NA) +
geom_sf(data = sf_com_mntd, aes(fill = f_obs_mntd_alien),
color = NA, dTolerance = 2, linewidth = 0.2, show.legend = F) +
scale_fill_manual(
values = colors2,
na.value = 'gray90',
name = 'mntd (Mya)',
guide = guide_legend(
title = "mntd (Mya)",
title.position = "top",
label.position = "bottom",
direction = "horizontal",
nrow = 1
)
) +
theme_void() +
theme(
legend.position = "bottom",
plot.title = element_text(face = "bold", size = 12,
hjust = 0.5),
)
legend.obs_mntd_alien_map = legend.func(mycolors = colors2,
mylabels = round(breaks_mntd, 1)) +
ggtitle("MNTD (Mya)") +
theme(plot.title = element_text(hjust = 0.5, size = 9))
obs_mntd_alien_map = ggplotGrob(obs_mntd_alien_map)
legend.obs_mntd_alien_map = ggplotGrob(legend.obs_mntd_alien_map)
obs_mntd_alien_map_all = arrangeGrob(obs_mntd_alien_map,
legend.obs_mntd_alien_map,
ncol = 1,
layout_matrix = rbind(matrix(1, 4, 10), c(NA, rep(2, 8), NA)))
plot(obs_mntd_alien_map_all)
ses_mntd_alien_map =
ggplot() +
geom_sf(data = countries, color = 'gray', fill = NA) +
geom_sf(data = bb, color = "gray", fill = NA) +
geom_sf(data = sf_com_mntd, aes(fill = f_ses_mntd_alien_1),
color = NA, dTolerance = 2, linewidth = 0.2, show.legend = F) +
scale_fill_manual(
values = colors2,
na.value = 'gray90',
name = 'mntd (Mya)',
guide = guide_legend(
title = "mntd (Mya)",
title.position = "top",
label.position = "bottom",
direction = "horizontal",
nrow = 1
)
) +
theme_void() +
theme(
legend.position = "bottom",
plot.title = element_text(face = "bold", size = 12,
hjust = 0.5),
)
legend.ses_mntd_alien_map = legend.func(mycolors = colors2,
mylabels = round(breaks_sesmntd, 1)) +
ggtitle(expression(Delta*"MNTD (Mya)")) +
theme(plot.title = element_text(hjust = 0.5, size = 9))
ses_mntd_alien_map = ggplotGrob(ses_mntd_alien_map)
legend.ses_mntd_alien_map = ggplotGrob(legend.ses_mntd_alien_map)
ses_mntd_alien_map_all = arrangeGrob(ses_mntd_alien_map,
legend.ses_mntd_alien_map,
ncol = 1,
layout_matrix = rbind(matrix(1, 4, 10), c(NA, rep(2, 8), NA)))
plot(ses_mntd_alien_map_all)
p.mntd_LAT=ggplot(sf_com_mntd, aes(x = abs_LAT,y = obs_mntd_alien)) +
geom_point(shape=19,alpha = 1,size=1.5,color="gray80") +
