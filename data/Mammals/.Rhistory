library(cowplot)
library(devEMF)
# Set plot width and height
plot_width = 0.50
plot_height = 0.24
v_spacing = 0.24  # vertical gap between plot rows
# Create the composite figure
fig_2_mntd = ggdraw() +
# Left column: stacked maps
draw_plot(obs_mntd_alien_map_all, x = 0, y = v_spacing, width = plot_width * 1.05, height = plot_height) +
draw_plot(ses_mntd_alien_map_all, x = 0, y = 0, width = plot_width * 1.05, height = plot_height) +
# Right column: stacked latitudinal patterns
draw_plot(p.mntd_LAT, x = 0.52, y = v_spacing, width = plot_width * 0.8, height = plot_height) +
draw_plot(p.SES.mntd_LAT, x = 0.52, y = 0, width = plot_width * 0.8, height = plot_height) +
# Add subplot labels
draw_plot_label(
label = c("a", "b", "c", "d"),
size = 16,
fontface = "bold",
x = c(0.01, 0.01, 0.53, 0.53),
y = c(v_spacing + plot_height - 0.01, plot_height - 0.01,
v_spacing + plot_height - 0.01, plot_height - 0.01)
)
pdf('figures/fig_2_mntd.pdf', height=40 * 0.4, width=25 * 0.4, fonts = 'ArialMT')
fig_2_mntd
dev.off() #turn off device and finalize file
p.mntd_LAT=ggplot(sf_com_mntd, aes(x = abs_LAT,y = obs_mntd_alien)) +
geom_point(shape=19,alpha = 1,size=1.5,color="gray80") +
#scale_color_manual(values = c("#601200","#013E7D","gray60"), drop = FALSE,
#                  breaks = c("Positive","Negative","NA"), labels = c("Significantly positive","Significantly negative","Non-significant"))+
geom_smooth(method = "lm", formula = y ~ x, se = T,size=1.5,color="gray23")+
stat_regline_equation(aes(x = abs_LAT,y = obs_mntd_alien, label = ..adj.rr.label..),
label.x = 5,label.y = 228,size=2.3)+
theme_classic() +
labs(x = "Absolute latitude (°)",y = "MNTD (Mya)")+
theme(axis.title =element_text(size=9),
axis.text = element_text(size = 7,colour = 'black'),
legend.position = c(0.7,0.9),
legend.background = element_blank(),
legend.text = element_text(size=7),
legend.key.width = unit(1,'line'),
legend.key.height = unit(1,'line'),
legend.title = element_blank()
)
p.mntd_LAT
cbPalette = c("gray65","#336633")#
p.SES.mntd_LAT=
ggplot(sf_com_mntd) +
geom_point(aes(x = abs_LAT, y = ses_mntd_alien_1),shape=19,alpha = 1,size=0.7,color="gray90") +
stat_smooth(aes(x = abs_LAT, y = ses_mntd_alien_1, colour ="Full.nonna",fill="Full.nonna"),
method = "lm", formula =y~x, se = T,lwd=1.3,alpha=0.35) +
stat_smooth(aes(x = abs_LAT, y = ses_mntd_alien_2, colour ="Conti.nonna",fill = "Conti.nonna"),
method = "lm", formula = y~x,se = T,lwd=1.5,alpha=0.35) +
scale_color_manual(name = "",breaks = c("Full.nonna","Conti.nonna"),
values = c("Full.nonna"=cbPalette[1], "Conti.nonna"=cbPalette[2]))+
scale_fill_manual(name = "",breaks = c("Full.nonna","Conti.nonna"),
values = c("Full.nonna"=cbPalette[1], "Conti.nonna"=cbPalette[2])) +
stat_regline_equation(aes(x = LAT,y = ses_mntd_alien_1,
label = paste("Global","nat.",..adj.rr.label.., sep = "*\"  \"*")),
label.x = 8,label.y = -1.45,size=2.3)+
stat_regline_equation(aes(x = abs_LAT,y = ses_mntd_alien_2,
label = paste("Continent","nat.",..adj.rr.label.., sep = "*\"  \"*")),
label.x = 8,label.y = -1.6,size=2.3)+
theme_classic() +
labs(x = "Absolute latitude (°)",y = expression(Delta*"MNTD (Mya)"))+
theme(axis.title =element_text(size=9),
axis.text = element_text(size = 7,colour = 'black'),
legend.title=element_blank(),
legend.text =element_blank(),
legend.key.width = unit(0.8,'line'),
legend.key.height = unit(0.56,'line'),
legend.position = c(0.09,0.21),
legend.background=element_blank())
p.SES.mntd_LAT
# Create the composite figure
fig_2_mntd = ggdraw() +
# Left column: stacked maps
draw_plot(obs_mntd_alien_map_all, x = 0, y = v_spacing, width = plot_width * 1.05, height = plot_height) +
draw_plot(ses_mntd_alien_map_all, x = 0, y = 0, width = plot_width * 1.05, height = plot_height) +
# Right column: stacked latitudinal patterns
draw_plot(p.mntd_LAT, x = 0.52, y = v_spacing, width = plot_width * 0.8, height = plot_height) +
draw_plot(p.SES.mntd_LAT, x = 0.52, y = 0, width = plot_width * 0.8, height = plot_height) +
# Add subplot labels
draw_plot_label(
label = c("a", "b", "c", "d"),
size = 16,
fontface = "bold",
x = c(0.01, 0.01, 0.53, 0.53),
y = c(v_spacing + plot_height - 0.01, plot_height - 0.01,
v_spacing + plot_height - 0.01, plot_height - 0.01)
)
pdf('figures/fig_2_mntd.pdf', height=40 * 0.4, width=25 * 0.4, fonts = 'ArialMT')
pdf('figures/fig_2_mntd.pdf', height=40 * 0.4, width=25 * 0.4, fonts = 'ArialMT')
fig_2_mntd
dev.off() #turn off device and finalize file
